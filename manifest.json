{
  "manifest_version": 3,

  "name": "Twitter scroller",
  "description": "Scroll to last liked",
  "version": "0.1",
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "run_at": "document_end",
      "js": ["script.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "scroll": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Scroll twitter feed until liked found"
    }
  }
}
